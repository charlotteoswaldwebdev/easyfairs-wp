{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Tech Expo",
  "settings": {
    "color": {
      "palette": [
        { "name": "Base", "slug": "base", "color": "#0A0F1E" },
        { "name": "Base Two", "slug": "base-two", "color": "#111827" },
        { "name": "Contrast", "slug": "contrast", "color": "#F1F5F9" },
        { "name": "Contrast Two", "slug": "contrast-two", "color": "#94A3B8" },
        { "name": "Primary", "slug": "primary", "color": "#00D4FF" },
        { "name": "Secondary", "slug": "secondary", "color": "#7C3AED" },
        { "name": "Accent", "slug": "accent", "color": "#06B6D4" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--space-grotesk)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "2px" }
      }
    }
  }
}
