{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Main Site",
  "settings": {
    "color": {
      "palette": [
        { "name": "Base", "slug": "base", "color": "#FFFFFF" },
        { "name": "Base Two", "slug": "base-two", "color": "#F4F6F9" },
        { "name": "Contrast", "slug": "contrast", "color": "#1A202C" },
        { "name": "Contrast Two", "slug": "contrast-two", "color": "#718096" },
        { "name": "Primary", "slug": "primary", "color": "#2B6CB0" },
        { "name": "Secondary", "slug": "secondary", "color": "#38A169" },
        { "name": "Accent", "slug": "accent", "color": "#D69E2E" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "6px" }
      }
    }
  }
}
