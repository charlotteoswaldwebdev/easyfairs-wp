{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Food Summit",
  "settings": {
    "color": {
      "palette": [
        { "name": "Base", "slug": "base", "color": "#FDFBF7" },
        { "name": "Base Two", "slug": "base-two", "color": "#F5F0E8" },
        { "name": "Contrast", "slug": "contrast", "color": "#1C1917" },
        { "name": "Contrast Two", "slug": "contrast-two", "color": "#78716C" },
        { "name": "Primary", "slug": "primary", "color": "#2D6A4F" },
        { "name": "Secondary", "slug": "secondary", "color": "#F4A261" },
        { "name": "Accent", "slug": "accent", "color": "#40916C" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--lato)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--playfair-display)",
          "fontWeight": "700"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "30px" }
      }
    }
  }
}
